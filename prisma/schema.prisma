// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                               String                            @id @default(uuid())
  email                            String                            @unique
  passwordHash                     String?
  name                             String
  googleId                         String?                           @unique
  isEmailVerified                  Boolean                           @default(true)
  verificationCode                 String?
  verificationCodeExpiresAt        DateTime?
  verificationAttempts             Int                               @default(0)
  passwordResetCode                String?
  passwordResetCodeExpiresAt       DateTime?
  currentBalance                   Float                             @default(0)
  balanceStartDate                 DateTime?
  greenThreshold                   Float                             @default(0)
  yellowThreshold                  Float                             @default(0)
  cashflowStartDay                 Int                               @default(1)
  ofxBankId                        String?
  ofxAcctId                        String?
  stripeCustomerId                 String?                           @unique
  stripeSubscriptionId             String?                           @unique
  plan                             Plan                              @default(FREE)
  planExpiresAt                    DateTime?
  createdAt                        DateTime                          @default(now())
  transactions                     Transaction[]
  recurringTemplates               RecurringTemplate[]
  categories                       Category[]
  goals                            Goal[]
  creditCards                      CreditCard[]
  creditCardPurchases              CreditCardPurchase[]
  creditCardInvoices               CreditCardInvoice[]
  installmentAdvances              InstallmentAdvance[]
  creditCardInvoiceAdvancePayments CreditCardInvoiceAdvancePayment[]
  importBatches                    ImportBatch[]
  notifications                    Notification[]
  pushSubscriptions                PushSubscription[]
  categoryBudgets                  CategoryBudget[]
}

model RecurringTemplate {
  id               String               @id @default(uuid())
  description      String
  estimatedAmount  Float
  type             TransactionType
  dayOfMonth       Int
  isActive         Boolean              @default(true)
  categoryId       String?
  userId           String
  endDate          DateTime?
  totalOccurrences Int?
  // Vinculado a um cartão: "realizar" cria uma CreditCardPurchase na fatura
  // do ciclo em vez de uma Transaction avulsa.
  creditCardId     String?
  creditCard       CreditCard?          @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  category         Category?            @relation(fields: [categoryId], references: [id])
  user             User                 @relation(fields: [userId], references: [id])
  createdAt        DateTime             @default(now())
  instances        Transaction[]
  purchases        CreditCardPurchase[]

  @@index([userId])
  @@index([creditCardId])
}

model Category {
  id                   String               @id @default(uuid())
  name                 String
  type                 TransactionType
  color                String?
  icon                 String?
  isDefault            Boolean              @default(false)
  // Se true, entradas com esta categoria contam como "entrada válida" no cálculo
  // do percentual de despesas sobre entradas (transferências ficam false).
  includeInBalanceBase Boolean              @default(true)
  // Direção do orçamento: LIMIT = estourar é ruim (ex.: Gasolina), GOAL = atingir
  // é bom (ex.: Investimento). Padrão por tipo na criação, mas o usuário escolhe.
  budgetDirection      BudgetDirection      @default(LIMIT)
  userId               String
  user                 User                 @relation(fields: [userId], references: [id])
  transactions         Transaction[]
  recurringTemplates   RecurringTemplate[]
  creditCardPurchases  CreditCardPurchase[]
  categoryBudgets      CategoryBudget[]

  @@index([userId])
}

enum BudgetDirection {
  LIMIT
  GOAL
}

// Orçamento definido pelo usuário para uma categoria, escopado a um ciclo
// específico (periodStart = início do ciclo, mesmo cálculo do frontend em
// getPeriodForDate/period.util.ts). Cada categoria pode ter no máximo um
// valor por período — sem repetição automática entre períodos.
model CategoryBudget {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  periodStart DateTime
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, periodStart])
  @@index([userId, periodStart])
}

model Transaction {
  id          String             @id @default(uuid())
  description String
  amount      Float
  type        TransactionType
  // Só preenchido para despesas (type = EXPENSE); null caso contrário.
  tipoDespesa ExpenseType?
  date        DateTime
  isPaid      Boolean            @default(false)
  isSkipped   Boolean            @default(false)
  templateId  String?
  template    RecurringTemplate? @relation(fields: [templateId], references: [id])
  categoryId  String?
  userId      String
  category    Category?          @relation(fields: [categoryId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  createdAt   DateTime           @default(now())

  // FITID do OFX. Único por usuário (que hoje representa a "conta" no app);
  // nulo para lançamentos manuais, o que permite múltiplos nulos sem colidir.
  fitId         String?
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  creditCardInvoice               CreditCardInvoice?
  creditCardInvoiceAdvancePayment CreditCardInvoiceAdvancePayment?

  @@unique([templateId, date])
  @@unique([userId, fitId])
  @@index([userId])
  @@index([templateId])
  @@index([date])
  @@index([categoryId])
  @@index([importBatchId])
}

enum TransactionType {
  INCOME
  EXPENSE
  INVESTMENT
}

// Classificação adicional de despesas. Só faz sentido quando type = EXPENSE;
// para os demais tipos permanece null.
enum ExpenseType {
  fixa
  variavel
}

enum Plan {
  FREE
  PRO
}

model Goal {
  id            String             @id @default(uuid())
  name          String
  description   String             @default("")
  icon          String
  color         String             @default("primary")
  targetAmount  Float
  savedAmount   Float              @default(0)
  deadline      DateTime
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  createdAt     DateTime           @default(now())
  contributions GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id          String   @id @default(uuid())
  amount      Float
  description String
  date        DateTime
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([goalId])
}

model CreditCard {
  id         String   @id @default(uuid())
  name       String
  closingDay Int
  dueDay     Int
  paymentDay Int
  isActive   Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  purchases          CreditCardPurchase[]
  invoices           CreditCardInvoice[]
  recurringTemplates RecurringTemplate[]

  @@index([userId])
}

model CreditCardPurchase {
  id                String     @id @default(uuid())
  description       String
  totalAmount       Float
  installmentsCount Int
  purchaseDate      DateTime
  isCredit          Boolean    @default(false)
  cardId            String
  card              CreditCard @relation(fields: [cardId], references: [id])
  userId            String
  user              User       @relation(fields: [userId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  originInvoiceId String?
  originInvoice   CreditCardInvoice? @relation("PurchaseOrigin", fields: [originInvoiceId], references: [id])

  // Compra materializada a partir de um recorrente de cartão; (templateId, purchaseDate)
  // é único para deduplicar o realize, espelhando Transaction @@unique([templateId, date]).
  templateId String?
  template   RecurringTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt    DateTime                @default(now())
  installments CreditCardInstallment[]
  advances     InstallmentAdvance[]

  @@unique([templateId, purchaseDate])
  @@index([userId])
  @@index([cardId])
  @@index([templateId])
  @@index([categoryId])
}

model CreditCardInstallment {
  id         String @id @default(uuid())
  number     Int
  totalCount Int
  amount     Float

  isAnticipated Boolean             @default(false)
  advanceId     String?
  advance       InstallmentAdvance? @relation(fields: [advanceId], references: [id])

  purchaseId String
  purchase   CreditCardPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  invoiceId String
  invoice   CreditCardInvoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([invoiceId])
  @@index([advanceId])
}

model CreditCardInvoice {
  id             String @id @default(uuid())
  referenceMonth Int
  referenceYear  Int

  closingDate           DateTime
  dueDate               DateTime
  paymentDate           DateTime
  paymentDateOverridden Boolean  @default(false)

  cardId String
  card   CreditCard @relation(fields: [cardId], references: [id])
  userId String
  user   User       @relation(fields: [userId], references: [id])

  isPaid     Boolean @default(false)
  paidAmount Float?

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  installments       CreditCardInstallment[]
  remainderPurchases CreditCardPurchase[]              @relation("PurchaseOrigin")
  advances           InstallmentAdvance[]
  advancePayments    CreditCardInvoiceAdvancePayment[]

  createdAt DateTime @default(now())

  @@unique([cardId, referenceYear, referenceMonth])
  @@index([userId])
  @@index([cardId])
  @@index([paymentDate])
}

// Débito registrado contra uma fatura ainda aberta (antes do fechamento),
// sem marcá-la como paga. É abatido do valor cobrado quando a fatura
// realmente fecha e é paga via CreditCardInvoicesService.pay.
model CreditCardInvoiceAdvancePayment {
  id        String            @id @default(uuid())
  invoiceId String
  invoice   CreditCardInvoice @relation(fields: [invoiceId], references: [id])
  userId    String
  user      User              @relation(fields: [userId], references: [id])

  amount      Float
  paymentDate DateTime

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([userId])
}

model InstallmentAdvance {
  id                String             @id @default(uuid())
  purchaseId        String
  purchase          CreditCardPurchase @relation(fields: [purchaseId], references: [id])
  invoiceId         String
  invoice           CreditCardInvoice  @relation(fields: [invoiceId], references: [id])
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  installmentsCount Int
  originalAmount    Float
  paidAmount        Float
  discount          Float
  anticipatedAt     DateTime           @default(now())

  anticipatedInstallments CreditCardInstallment[]

  @@index([purchaseId])
  @@index([invoiceId])
  @@index([userId])
}

enum ImportBatchStatus {
  PENDING_REVIEW
  CONFIRMED
  CANCELED
  ROLLED_BACK
}

enum ImportItemStatus {
  NEW
  DUPLICATE_EXACT
  POSSIBLE_DUPLICATE
}

enum ImportItemDecision {
  IMPORT
  SKIP
}

enum NotificationType {
  RECURRING_DUE
  INVOICE_DUE
  BALANCE_WARNING
  BUDGET_WARNING
  GENERIC
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  // {type}:{entityId}:{YYYY-MM-DD} — used by the cron job to skip already-sent notifications
  dedupeKey String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, dedupeKey])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Um lote de importação de OFX. Fica em PENDING_REVIEW até o usuário confirmar
// na tela de revisão; só aí os itens decididos como IMPORT viram Transaction.
model ImportBatch {
  id       String            @id @default(uuid())
  userId   String
  user     User              @relation(fields: [userId], references: [id])
  fileName String
  bankId   String?
  acctId   String?
  status   ImportBatchStatus @default(PENDING_REVIEW)

  totalCount             Int @default(0)
  newCount               Int @default(0)
  duplicateExactCount    Int @default(0)
  possibleDuplicateCount Int @default(0)
  importedCount          Int @default(0)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  items        ImportBatchItem[]
  transactions Transaction[]

  @@index([userId])
}

// Transação extraída do OFX antes de ser persistida como Transaction de fato.
model ImportBatchItem {
  id      String      @id @default(uuid())
  batchId String
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  fitId       String?
  description String
  amount      Float
  type        TransactionType
  date        DateTime

  status               ImportItemStatus
  matchedTransactionId String?
  similarityScore      Float?
  decision             ImportItemDecision?

  createdAt DateTime @default(now())

  @@index([batchId])
}
