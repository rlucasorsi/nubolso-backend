# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Frontend origins allowed by CORS (comma-separated, add Vercel URL in production)
FRONTEND_URL=http://localhost:3001/

JWT_SECRET="troque-antes-de-subir"
JWT_EXPIRES_IN="7d"

# SMTP (e-mails de confirmação e redefinição de senha).
# Se não configurado, os e-mails são apenas logados no console (modo dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Login com Google (ID token, verificado via google-auth-library).
# Se não configurado, o botão "Continuar com Google" fica oculto no frontend.
GOOGLE_CLIENT_ID=

RESEND_API_KEY=
RESEND_FROM=no-reply@seudominio.com
